# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# --- Supabase (database, auth, leads CRM) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email — questionnaire flow) ---
RESEND_API_KEY=
# Optional. Defaults to "Bluevera Residences <onboarding@resend.dev>".
RESEND_FROM_EMAIL=

# --- Cloudflare Turnstile (CAPTCHA — questionnaire flow) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- MailerLite (winter-guide landing — embedded "Winter Guide download form") ---
# Both values are public, non-secret IDs. Copy them from MailerLite:
#   Account ID: shown in the embed snippet as  ml('account', 'XXXXXXX')
#   Form ID:    Forms > "Winter Guide download form" > Edit > Embed >
#               JavaScript snippet > data-form="XXXXXXX"
NEXT_PUBLIC_MAILERLITE_ACCOUNT_ID=
NEXT_PUBLIC_MAILERLITE_FORM_ID=

# --- Site ---
# Optional. Defaults to https://www.blueveraresidences.com.
NEXT_PUBLIC_SITE_URL=
